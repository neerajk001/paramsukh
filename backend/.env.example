# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/paramsukh
# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/paramsukh

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ADMIN_API_KEY=replace_with_strong_admin_api_key
ADMIN_COOKIE_PASSWORD=replace_with_64_char_random_secret
ADMIN_SESSION_SECRET=replace_with_64_char_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password

# Fast2SMS Configuration (for OTP)
# Get your API key from: https://www.fast2sms.com/dashboard/dev-api
# For Development: Set to 'test' to log OTPs to console (no SMS sent - FREE)
# For Production: Add your actual Fast2SMS API key
FAST2SMS_API_KEY=test

# Google OAuth (Optional - app login)
GOOGLE_WEB_CLIENT=366705469295-3tkkjn90k1djaskamei17bio0qeuhov4.apps.googleusercontent.com
ANDROID_GOOGLE_CLIENT=366705469295-rhso5ojpvo3ajk4901b0p0f28kejs794.apps.googleusercontent.com

# Admin panel: Google OAuth (NextAuth). Create OAuth 2.0 Web client in Google Cloud Console.
# Use same project; add authorized redirect URI: http://localhost:3001/api/auth/callback/google (and your production URL)
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_web_client_secret

# Razorpay Configuration (Payment Gateway)
# Get Test Keys from: https://dashboard.razorpay.com/app/keys
# Leave empty or set to 'test' to use TEST MODE (no real keys needed)
RAZORPAY_KEY_ID=test
# For production, use: rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# For production, add your secret key
RAZORPAY_WEBHOOK_SECRET=
# Optional: For webhook verification

# Cloudinary Configuration (File Upload - Images & Videos)
# Get from: https://cloudinary.com/console
# Leave empty or set to 'test' to use TEST MODE (no real account needed)
CLOUDINARY_CLOUD_NAME=test
# For production, use your actual cloud name
CLOUDINARY_API_KEY=
# For production, add your API key
CLOUDINARY_API_SECRET=
# For production, add your API secret

# Email Configuration (Resend)

