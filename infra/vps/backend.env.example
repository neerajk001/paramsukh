NODE_ENV=production
PORT=3000

# Required
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/paramsukh
JWT_SECRET=replace_with_64_char_random_secret
ADMIN_API_KEY=replace_with_strong_admin_api_key

# Strongly recommended for admin module
ADMIN_COOKIE_PASSWORD=replace_with_64_char_random_secret
ADMIN_SESSION_SECRET=replace_with_64_char_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_admin_password

# OAuth (if using Google login)
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_web_client_secret

# OTP provider
FAST2SMS_API_KEY=your_fast2sms_api_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email
RESEND_API_KEY=your_resend_api_key


