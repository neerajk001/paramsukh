# Image overrides written by CI deploy step
BACKEND_IMAGE=ghcr.io/your-org/saas-native-backend:latest
ADMIN_IMAGE=ghcr.io/your-org/saas-native-admin:latest

# Build/runtime variable for admin frontend API base URL
NEXT_PUBLIC_API_URL=https://api.example.com

# Build-time public admin API key injected into admin frontend bundle.
# Must match backend/.env -> ADMIN_API_KEY exactly.
NEXT_PUBLIC_ADMIN_API_KEY=replace_with_same_value_as_backend_admin_api_key
