NODE_ENV=production
PORT=3001

# Public API consumed by browser/admin app
NEXT_PUBLIC_API_URL=https://api.example.com

# NextAuth
NEXTAUTH_URL=https://admin.example.com
NEXTAUTH_SECRET=replace_with_64_char_random_secret

# Google OAuth web app credentials
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_web_client_secret
